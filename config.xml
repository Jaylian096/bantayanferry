<?xml version="1.0" encoding="UTF-8"?>
<widget id="com.bantayanferry.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
  <name>Bantayan Ferry</name>
  <description>Ferry booking app for Bantayan Island routes</description>
  <author email="dev@bantayanferry.com" href="https://bantayanferry.com">Bantayan Ferry Dev Team</author>
  
  <content src="index.html" />
  
  <access origin="*" />
  <allow-intent href="http://*/*" />
  <allow-intent href="https://*/*" />
  <allow-navigation href="*" />

  <!-- Plugins -->
  <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
  <plugin name="cordova-plugin-network-information" spec="^3.0.0" />
  <plugin name="cordova-plugin-device" spec="^2.1.0" />
  <plugin name="phonegap-plugin-barcodescanner" spec="^8.1.0" />

  <!-- Android -->
  <platform name="android">
    <preference name="android-minSdkVersion" value="22" />
    <preference name="android-targetSdkVersion" value="33" />
    <allow-intent href="market:*" />
    <icon src="res/icon/android/icon-192x192.png" density="xxxhdpi" />
  </platform>

  <!-- iOS -->
  <platform name="ios">
    <allow-intent href="itms:*" />
    <allow-intent href="itms-apps:*" />
  </platform>

  <preference name="DisallowOverscroll" value="true" />
  <preference name="Orientation" value="portrait" />
  <preference name="BackgroundColor" value="0xff0a2540" />
  <preference name="LoadingDialog" value="Loading,Please wait..." />
</widget>
